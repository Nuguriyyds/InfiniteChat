              "raw": "{{base_url}}/api/v1/user/logout",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "user", "logout"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var res = pm.response.json();",
                  "pm.test('A登出成功', function() {",
                  "  pm.expect(res.code).to.eql(200);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "8.2 旧Token访问-应401",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{tokenA}}" },
              { "key": "X-User-Id", "value": "{{userIdA}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/contact/list",
              "host": ["{{base_url}}"],
              "path": ["api", "contact", "list"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('登出后旧Token应被拒绝', function() {",
                  "  pm.expect(pm.response.code).to.eql(401);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
