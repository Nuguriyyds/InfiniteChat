    {
      "name": "4. 群聊",
      "item": [
        {
          "name": "4.1 A创建群聊(拉B和C入群)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{tokenA}}" },
              { "key": "X-User-Id", "value": "{{userIdA}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/message/session/createGroup",
              "host": ["{{base_url}}"],
              "path": ["api", "message", "session", "createGroup"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"\",\n  \"memberIds\": [{{userIdB}}, {{userIdC}}]\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var res = pm.response.json();",
                  "console.log('创建群聊响应:', JSON.stringify(res));",
                  "if (res.code === 200 && res.data && res.data.sessionId) {",
                  "  pm.collectionVariables.set('groupSessionId', res.data.sessionId);",
                  "  console.log('groupSessionId:', res.data.sessionId);",
