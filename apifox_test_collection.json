            ],
            "url": {
              "raw": "{{base_url}}/api/v1/user/noToken/register",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "user", "noToken", "register"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"{{phoneA}}\",\n  \"password\": \"{{password}}\",\n  \"code\": \"1234\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var res = pm.response.json();",
                  "console.log('注册用户A响应:', JSON.stringify(res));",
                  "if (res.code === 200 && res.data) {",
                  "  // data 可能是 userId 字符串或对象",
                  "  if (typeof res.data === 'object' && res.data.userId) {",
                  "    pm.collectionVariables.set('userIdA', String(res.data.userId));",
                  "  }",
                  "}",
                  "pm.test('注册用户A成功', function() {",
