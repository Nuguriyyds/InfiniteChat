    {
      "name": "3. 单聊消息",
      "item": [
        {
          "name": "3.0 获取单聊会话ID",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{tokenA}}" },
              { "key": "X-User-Id", "value": "{{userIdA}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/message/session/createSingle?userIdA={{userIdA}}&userIdB={{userIdB}}",
              "host": ["{{base_url}}"],
              "path": ["api", "message", "session", "createSingle"],
              "query": [
                { "key": "userIdA", "value": "{{userIdA}}" },
                { "key": "userIdB", "value": "{{userIdB}}" }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var res = pm.response.json();",
                  "console.log('获取单聊会话响应:', JSON.stringify(res));",
                  "if (res.code === 200 && res.data && res.data.sessionId) {",
                  "  pm.collectionVariables.set('sessionId', res.data.sessionId);",
                  "  console.log('sessionId:', res.data.sessionId);",
                  "}",
                  "pm.test('获取单聊会话ID成功', function() {",
                  "  pm.expect(res.code).to.eql(200);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "3.1 A给B发消息",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{tokenA}}" },
              { "key": "X-User-Id", "value": "{{userIdA}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/message/send",
              "host": ["{{base_url}}"],
              "path": ["api", "message", "send"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"clientMsgId\": \"test-single-msg-001\",\n  \"sessionId\": \"{{sessionId}}\",\n  \"sessionType\": 1,\n  \"type\": 1,\n  \"receiveUserId\": {{userIdB}},\n  \"body\": {\n    \"content\": \"你好B，这是单聊测试消息！\"\n  }\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var res = pm.response.json();",
                  "console.log('A发消息响应:', JSON.stringify(res));",
                  "if (res.sessionId) {",
                  "  pm.collectionVariables.set('sessionId', res.sessionId);",
                  "}",
                  "if (res.messageId) {",
                  "  pm.collectionVariables.set('messageId', res.messageId);",
                  "}",
                  "pm.collectionVariables.set('clientMsgId1', 'test-single-msg-001');",
                  "pm.test('A给B发消息成功', function() {",
                  "  pm.expect(pm.response.code).to.eql(200);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "3.2 B给A发消息",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{tokenB}}" },
              { "key": "X-User-Id", "value": "{{userIdB}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/message/send",
              "host": ["{{base_url}}"],
              "path": ["api", "message", "send"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"clientMsgId\": \"test-single-msg-002\",\n  \"sessionId\": \"{{sessionId}}\",\n  \"sessionType\": 1,\n  \"type\": 1,\n  \"receiveUserId\": {{userIdA}},\n  \"body\": {\n    \"content\": \"你好A，收到你的消息了！\"\n  }\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('B给A发消息成功', function() {",
                  "  pm.expect(pm.response.code).to.eql(200);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "3.3 幂等验证-重复clientMsgId",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{tokenA}}" },
              { "key": "X-User-Id", "value": "{{userIdA}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/message/send",
              "host": ["{{base_url}}"],
              "path": ["api", "message", "send"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"clientMsgId\": \"test-single-msg-001\",\n  \"sessionId\": \"{{sessionId}}\",\n  \"sessionType\": 1,\n  \"type\": 1,\n  \"receiveUserId\": {{userIdB}},\n  \"body\": {\n    \"content\": \"这是重复消息，应该被拦截\"\n  }\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('重复clientMsgId应被拦截', function() {",
                  "  var code = pm.response.code;",
                  "  // 期望非200或响应体中有错误提示",
                  "  var res = pm.response.json();",
                  "  console.log('幂等验证响应:', JSON.stringify(res));",
                  "});"
                ]
              }
            }
          ]
        }
      ]
